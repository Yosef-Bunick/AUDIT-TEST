# Normalize line endings on commit; keep LF in the repo regardless of OS.
# Prevents CRLF churn across the WSL/Windows split.
* text=auto eol=lf

# Explicit for the languages this repo actually contains.
*.py    text eol=lf
*.toml  text eol=lf
*.md    text eol=lf
*.json  text eol=lf
*.cfg   text eol=lf
*.txt   text eol=lf
*.sh    text eol=lf
